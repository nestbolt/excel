{
  "name": "@nestbolt/excel",
  "version": "0.3.0",
  "packageManager": "pnpm@9.15.4",
  "description": "Supercharged Excel and CSV exports and imports for NestJS applications. Effortlessly create, download, and import spreadsheets with powerful features and seamless integration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:results": "npx vitest run --coverage 2>&1 | grep -E \"All files|%\" | head -10",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "excel",
    "xlsx",
    "csv",
    "export",
    "import",
    "spreadsheet",
    "download",
    "s3",
    "gcs",
    "azure",
    "storage"
  ],
  "author": "Nestbolt",
  "license": "MIT",
  "homepage": "https://github.com/nestbolt/excel#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestbolt/excel"
  },
  "bugs": {
    "url": "https://github.com/nestbolt/excel/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@google-cloud/storage": "^7.0.0",
    "@azure/storage-blob": "^12.0.0",
    "@azure/identity": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "@azure/storage-blob": {
      "optional": true
    },
    "@azure/identity": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@google-cloud/storage": "^7.19.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}